```gitignore
# Dependencies
node_modules/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
venv/
env/
ENV/
.venv/
.env
.env.local
.env.*
.envrc

# Build outputs
dist/
build/
target/
.out
.o
.obj

# Logs
*.log

# Temporary files
*.tmp
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# IDE specific
.vscode/
.idea/
*.iml
*.ipr
*.iws

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
```