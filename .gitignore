```gitignore
# Dependencies
node_modules/
.pnpm-store/
.npm/
.yarn/

# Build outputs
dist/
build/
coverage/
.eslintcache

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.*
!.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# TypeScript
*.tsbuildinfo
```