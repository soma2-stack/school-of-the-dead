npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Compiled binary files
*.exe
*.dll
*.so
*.dylib
*.o
*.obj
*.a
*.lib
*.out

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo

# Coverage reports
coverage/
coverage.xml
*.gcov
*.lcov

# Temporary files
*.tmp
*.temp
*~
.DS_Store
Thumbs.db

# Testing
.nyc_output/
coverage/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
